# ─── 必须配置 ───
# 你的 API Key（支持 OpenAI / DeepSeek / 通义千问 等兼容接口）
LLM_API_KEY=sk-your-api-key-here

# ─── 可选配置 ───
# API 基础地址（默认 OpenAI，改成 DeepSeek 就填 https://api.deepseek.com）
LLM_BASE_URL=https://api.openai.com/v1

# 使用的模型
LLM_MODEL=gpt-4o-mini

# 服务端口
PORT=8000

# 数据库路径（默认使用项目目录下的 data/chatbot.db）
DATABASE_PATH=

# 系统提示词（给 AI 的角色设定）
SYSTEM_PROMPT=你是一个专业、热情的电商客服助手。你叫小智，来自智联客服团队。你回答简洁专业，对客户的问题给予清晰准确的解答。
